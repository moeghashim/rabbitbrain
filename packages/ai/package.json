{
	"name": "@pi-starter/ai",
	"version": "0.0.1",
	"description": "Shared AI provider adapters and model catalog",
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist/**/*",
		"README.md",
		"CHANGELOG.md"
	],
	"scripts": {
		"clean": "rm -rf dist",
		"build": "tsgo -p tsconfig.build.json",
		"dev": "tsgo -p tsconfig.build.json --watch --preserveWatchOutput",
		"test": "tsx --test test/**/*.test.ts",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"dependencies": {
		"@pi-starter/contracts": "0.0.1",
		"@pi-starter/core": "0.0.1",
		"@pi-starter/x-client": "0.0.1"
	}
}
