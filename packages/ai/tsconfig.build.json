{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"outDir": "./dist",
		"rootDir": "./src",
		"paths": {
			"@pi-starter/contracts": ["../contracts/src/index.ts"],
			"rabbitbrain": ["../core/src/index.ts"],
			"@pi-starter/x-client": ["../x-client/src/index.ts"]
		}
	},
	"include": [
		"src/**/*.ts"
	],
	"exclude": [
		"node_modules",
		"dist",
		"**/*.d.ts",
		"src/**/*.d.ts"
	]
}
