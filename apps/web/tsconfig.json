{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["DOM", "DOM.Iterable", "ES2022"],
		"jsx": "preserve",
		"incremental": true,
		"allowJs": false,
		"noEmit": true,
		"plugins": [{ "name": "next" }],
		"moduleResolution": "Bundler",
		"module": "ESNext",
		"isolatedModules": true
	},
	"include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
	"exclude": ["node_modules"]
}
